@model IEnumerable<SpecialResearch.Models.Request>

@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>
<p>
    <a asp-action="Create">Создать новую заявку</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Number)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreateDate)
            </th>
            <th>
                Этап заявки
            </th>
            <th>
                @Html.DisplayNameFor(model => model.User)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.User1)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UseOrder)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PhotoCopy)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                <a asp-controller="Equipments" asp-action="List" asp-route-id="@item.Id">
                    @Html.DisplayFor(modelItem => item.Number)
                    </a>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreateDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Stage.StageName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.User.Name)
            </td>
            <td>
                @if (item.User1.Id != 1) Html.DisplayFor(modelItem => item.User1.Name);
            </td>
            <td>
                @if (item.UseOrder == 0) Html.DisplayText("Не выдано"); else Html.DisplayText("Выдано");
            </td>
            <td>
                @if (item.EndDate != null) Html.DisplayFor(modelItem => item.EndDate);
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PhotoCopy)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                <a asp-action="NextStage" asp-route-id="@item.Id">Перевести на следующий этап</a>
            </td>
        </tr>
}
    </tbody>
</table>
</body>
</html>
